# ============================================================================
# Computronium environment variables
#
# Copy this file to `.env.local` for local development, and add the same
# variables in the Vercel dashboard (Project → Settings → Environment
# Variables) when you deploy.
#
# Everything here comes from the FREE Supabase tier — no paid services.
# ============================================================================

# --- Supabase (required) ----------------------------------------------------
# Find these in your Supabase project: Settings → API.
# The URL and the "anon / public" key are safe to expose to the browser
# (that's why they start with NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# The "service_role" key is SECRET. It bypasses row-level security and is
# only ever used inside server code (API routes). Never expose it in the
# browser and never commit it to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Admin ------------------------------------------------------------------
# The username that gets admin powers (delete any post, curate the
# Alternatives page, pin posts). Sign up normally with this username, then
# set it here. You can also flip `is_admin` on your row in the `profiles`
# table for the same effect.
ADMIN_USERNAME=your-username-here

# --- AI (future — leave empty for now) --------------------------------------
# When you're ready to enable the "✨ Suggest instructions" button, paste an
# API key here and follow the comments in lib/ai.ts. Until then the AI
# features stay disabled and the site works 100% without this.
AI_API_KEY=
